# =============================================================================
# Varo Admin Console — Environment Variables
# =============================================================================
#
# Copy to create local config (gitignored):
#
#   cp .env.example .env.development
#
# All variables must be prefixed with VITE_ to be exposed to the client bundle.
# =============================================================================

# -----------------------------------------------------------------------------
# API & Mock
# -----------------------------------------------------------------------------

# Enable vite-plugin-mock during `npm run dev`.
# true  = offline mock data
# false = real backend via VITE_DEV_API_PROXY_TARGET (local or staging)
VITE_USE_MOCK=true

# API base path. With proxy: /api → forwarded to VITE_DEV_*_API_PROXY_TARGET
# Deployed (GitHub Pages):
#   VITE_API_BASE_URL=https://admin.varo.cloud/api
#   VITE_USER_API_BASE_URL=https://api.varo.cloud/api
VITE_API_BASE_URL=/api
# VITE_USER_API_BASE_URL=https://staging.api.varo.cloud/api

# Public base path when deployed under a subdirectory (GitHub Pages: /admin-web/)
VITE_BASE=/

# -----------------------------------------------------------------------------
# Local development only (npm run dev)
# -----------------------------------------------------------------------------

# Proxy /api to a real backend. Required when VITE_USE_MOCK=false.
#
# Split mode (user + admin on different ports):
VITE_DEV_USER_API_PROXY_TARGET=http://localhost:8000
VITE_DEV_ADMIN_API_PROXY_TARGET=http://localhost:8001
#
# Single backend (all /api → one target):
# VITE_DEV_API_PROXY_TARGET=https://staging.api.varo.cloud

# Optional: skip login during local dev. Paste admin access_token from staging;
# written to localStorage on dev server start.
VITE_DEV_AUTH_TOKEN=

# Optional: refresh_token paired with VITE_DEV_AUTH_TOKEN.
VITE_DEV_REFRESH_TOKEN=

# Deprecated — use VITE_DEV_AUTH_TOKEN instead.
# VITE_DEV_BEARER_TOKEN=
